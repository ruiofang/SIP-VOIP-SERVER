# ===== 服务监听 =====
SIP_HOST=0.0.0.0
SIP_PORT=5060
API_HOST=0.0.0.0
API_PORT=8000

# 对外宣告地址（公网 IP / 域名），ESP32 等客户端通过它连接
PUBLIC_HOST=your.aliyun.public.ip
PUBLIC_SIP_PORT=5060

# ===== RTP 媒体中继 =====
# 偶数=RTP，奇数=RTCP；容器/安全组需放行整段 UDP
RTP_PORT_MIN=20000
RTP_PORT_MAX=20199

# ===== 数据库 =====
# 本地 SQLite：sqlite+aiosqlite:///./sip.db
# 阿里云 RDS MySQL：mysql+aiomysql://user:pass@rm-xxx.mysql.rds.aliyuncs.com:3306/sip
DATABASE_URL=sqlite+aiosqlite:///./sip.db

# ===== 安全 =====
JWT_SECRET=please-change-to-a-long-random-secret-string
SIP_REALM=sip.example.com
ADMIN_DEFAULT_USER=admin
ADMIN_DEFAULT_PASS=admin123

# ===== 媒体存储 =====
VOICE_STORAGE_DIR=./voice_storage
VOICE_MAX_BYTES=2097152

# ===== 日志 =====
LOG_LEVEL=INFO
